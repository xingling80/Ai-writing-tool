{
  "name": "ai-writing-tool",
  "version": "1.0.1",
  "description": "AI Writing Tool",
  "main": "main-electron.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.aiwriting.tool",
    "productName": "AI Writing Tool",
    "artifactName": "${productName}-setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main-electron.js",
      "preload.js",
      "index.html",
      "pages/**/*",
      "js/**/*",
      "css/**/*",
      "assets/**/*",
      "partials/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Writing Tool"
    },
    "publish": {
      "provider": "github",
      "owner": "xingling80",
      "repo": "Ai-writing-tool",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  }
}
